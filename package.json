{
  "name": "vscode-claude-status",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "l10n": "./l10n",
  "version": "0.4.2",
  "publisher": "long-kudo",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "real-time",
    "usage",
    "cost",
    "customization",
    "monitoring",
    "visualization",
    "anthropic",
    "token",
    "dashboard",
    "status-bar"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/long-910/vscode-claude-status"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/long-910"
  },
  "bugs": {
    "url": "https://github.com/long-910/vscode-claude-status/issues"
  },
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-claude-status.openDashboard",
        "title": "%cmd.openDashboard%"
      },
      {
        "command": "vscode-claude-status.refresh",
        "title": "%cmd.refresh%"
      },
      {
        "command": "vscode-claude-status.toggleDisplayMode",
        "title": "%cmd.toggleDisplayMode%"
      },
      {
        "command": "vscode-claude-status.setBudget",
        "title": "%cmd.setBudget%"
      }
    ],
    "keybindings": [
      {
        "command": "vscode-claude-status.toggleDisplayMode",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "claudeStatus.displayMode": {
          "type": "string",
          "enum": [
            "percent",
            "cost"
          ],
          "default": "percent",
          "description": "%config.displayMode.desc%"
        },
        "claudeStatus.statusBar.alignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "%config.statusBar.alignment.desc%"
        },
        "claudeStatus.statusBar.showProjectCost": {
          "type": "boolean",
          "default": true,
          "description": "%config.statusBar.showProjectCost.desc%"
        },
        "claudeStatus.cache.ttlSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "maximum": 3600,
          "description": "%config.cache.ttlSeconds.desc%"
        },
        "claudeStatus.rateLimitApi.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.rateLimitApi.enabled.desc%"
        },
        "claudeStatus.realtime.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.realtime.enabled.desc%"
        },
        "claudeStatus.budget.dailyUsd": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "description": "%config.budget.dailyUsd.desc%"
        },
        "claudeStatus.budget.weeklyUsd": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "description": "%config.budget.weeklyUsd.desc%"
        },
        "claudeStatus.budget.alertThresholdPercent": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "%config.budget.alertThresholdPercent.desc%"
        },
        "claudeStatus.notifications.rateLimitWarning": {
          "type": "boolean",
          "default": true,
          "description": "%config.notifications.rateLimitWarning.desc%"
        },
        "claudeStatus.notifications.rateLimitWarningThresholdMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 120,
          "description": "%config.notifications.rateLimitWarningThresholdMinutes.desc%"
        },
        "claudeStatus.notifications.budgetWarning": {
          "type": "boolean",
          "default": true,
          "description": "%config.notifications.budgetWarning.desc%"
        },
        "claudeStatus.heatmap.days": {
          "type": "number",
          "default": 90,
          "enum": [
            30,
            60,
            90
          ],
          "description": "%config.heatmap.days.desc%"
        },
        "claudeStatus.credentials.path": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%config.credentials.path.desc%"
        },
        "claudeStatus.claudeProvider": {
          "type": "string",
          "enum": [
            "auto",
            "claude-ai",
            "aws-bedrock",
            "api-key"
          ],
          "enumDescriptions": [
            "%config.claudeProvider.auto%",
            "%config.claudeProvider.claudeAi%",
            "%config.claudeProvider.awsBedrock%",
            "%config.claudeProvider.apiKey%"
          ],
          "default": "auto",
          "description": "%config.claudeProvider.desc%"
        },
        "claudeStatus.pricing.inputPerMillion": {
          "type": "number",
          "default": 3.0,
          "minimum": 0,
          "description": "%config.pricing.inputPerMillion.desc%"
        },
        "claudeStatus.pricing.outputPerMillion": {
          "type": "number",
          "default": 15.0,
          "minimum": 0,
          "description": "%config.pricing.outputPerMillion.desc%"
        },
        "claudeStatus.pricing.cacheReadPerMillion": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "description": "%config.pricing.cacheReadPerMillion.desc%"
        },
        "claudeStatus.pricing.cacheCreatePerMillion": {
          "type": "number",
          "default": 3.75,
          "minimum": 0,
          "description": "%config.pricing.cacheCreatePerMillion.desc%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "ts-loader": "^9.5.2",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
